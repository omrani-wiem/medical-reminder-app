# ⚛️ Image Node.js officielle
FROM node:18-alpine

# 📁 Répertoire de travail
WORKDIR /app

# 📋 Copier package.json et package-lock.json
COPY package*.json ./

# 📦 Installer les dépendances (optimisé pour cache Docker)
RUN npm ci --only=production

# 📁 Copier tout le code source
COPY . .

# 🌐 Exposer le port 3000
EXPOSE 3000

# 🏃‍♂️ Démarrer en mode développement
CMD ["npm", "start"]
